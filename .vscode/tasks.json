{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bun test --watch",
      "type": "shell",
      "command": "bun test --watch ./tests/*.test.ts",
      "group": "test",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "bun watch"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": {
        "owner": "bun",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^\\s+(\\S+\\.ts):(\\d+):(\\d+)\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^bun test",
          "endsPattern": "^\\s+\\d+ (pass|fail)"
        }
      }
    }
  ]
}
